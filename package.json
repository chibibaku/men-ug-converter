{
  "name": "men-ug-converter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "clean:deps": "node -e \"require('node:fs').rmSync('node_modules', { recursive: true, force: true })\"",
    "reinstall": "npm run clean:deps && npm install --include=optional --os=win32 --cpu=x64",
    "verify:rollup": "node -e \"require('rollup')\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
